<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <!-- Shared local nuget feed used by every CritterStack repo (jasperfx →
         marten → wolverine.critterwatch → critterwatch) for per-iteration
         alpha builds during cross-repo work. See critterwatch/nuget.config
         for the canonical layout this matches. Repo-local sources merge with
         the user-level config at ~/.nuget/NuGet/NuGet.Config — nuget.org
         stays the default for everything that isn't explicitly mapped below. -->
    <add key="local-nuget" value="/Users/jeremymiller/code/local-nuget" />
  </packageSources>

  <!-- #4596 / CritterWatch#209: the per-tenant-partitioning work needs the
       jasperfx#407 surface that hasn't shipped to nuget.org yet. JasperFx.*
       packages resolve from the local pack feed so this branch can develop
       against the new contracts without polluting nuget.org with alpha bits.
       Everything else falls through to nuget.org via the user-level config. -->
  <packageSourceMapping>
    <packageSource key="local-nuget">
      <package pattern="JasperFx" />
      <package pattern="JasperFx.Events" />
      <package pattern="JasperFx.Events.SourceGenerator" />
      <package pattern="JasperFx.SourceGenerator" />
      <package pattern="JasperFx.Aspire" />
    </packageSource>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
