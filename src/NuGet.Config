<?xml version="1.0" encoding="utf-8"?>
<configuration>
    <packageSources>
        <!-- Local-pack source for in-flight JFx.Events alphas while the upstream
             publish workflow has not yet cut a real alpha. The 2.0.0-localpack.1
             package contains the JasperFx #274 + #275 lifts merged on top of the
             2.0.0-alpha.6 baseline. REMOVE alongside the JasperFx.Events pin
             flip back to 2.0.0-alpha.7 (or later) once the real publish lands. -->
        <add key="jfx-local" value="/tmp/jfx-local-nupkgs" />
        <!-- Uncomment to use Npgsql prerelease package source
        <add key="Npgsql" value="https://www.myget.org/F/npgsql/api/v3/index.json" />-->
    </packageSources>
</configuration>